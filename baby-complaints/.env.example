# .env.example — Purchase Coherence Engine configuration template
# Copy this file to .env and fill in the values before running the server.
# Never commit the actual .env file to source control.

# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────
# Get your API key from https://openrouter.ai/keys
# Required for LLM-powered conflict analysis and bilingual copy generation.
# Without this, the system degrades gracefully to heuristic analysis.
OPENROUTER_API_KEY=

# OpenRouter model to use for LLM calls.
# Default: openai/gpt-3.5-turbo  (fast, cheap, good JSON mode support)
# Alternatives: mistralai/mistral-7b-instruct, openai/gpt-4o, anthropic/claude-3-haiku
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# OpenRouter completions endpoint — no need to change unless using a proxy.
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# ── Data ──────────────────────────────────────────────────────────────────────
# Path to the synthetic product CSV dataset.
# Switch to products_demo.csv for the 5-scenario demo.
DATA_PATH=./app/data/products_sample.csv

# ── Logging ───────────────────────────────────────────────────────────────────
# Log verbosity. Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=0.1.0
